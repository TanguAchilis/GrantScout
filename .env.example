# =============================================================================
# GrantScout — environment template. PLACEHOLDERS ONLY.
# Copy to `.env` (gitignored) and fill in a REAL key in Phase 2 (Antigravity).
# Phase 1 runs entirely offline: with no key set, the LLM nodes fall back to
# deterministic generation, so the catalog + eligibility + review-gate spine
# still runs end-to-end. NEVER commit a real value here.
# =============================================================================

# --- Option A: Google AI Studio API key (simplest local path; Phase 2) ---
# Get one at https://aistudio.google.com/apikey  (do NOT paste it into this file)
GOOGLE_API_KEY=your-google-ai-studio-key-here

# --- Option B: Vertex AI via gcloud Application Default Credentials (Phase 2) ---
# Set these instead of GOOGLE_API_KEY to use Vertex; leave GOOGLE_API_KEY blank.
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Model (overrides grantscout/config.py default if set) ---
GRANTSCOUT_MODEL=gemini-flash-latest
