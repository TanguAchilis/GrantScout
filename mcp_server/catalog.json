{
  "_about": {
    "what": "Curated catalog of African funding opportunities for NGOs/CBOs and startups/social enterprises.",
    "why": "There is no single free official African-grants API. This catalog consolidates REAL opportunities that appear across PUBLIC funding roundups into one queryable shape. That consolidation is the contribution.",
    "honesty": "Every entry is attributed to the public roundup/source where such opportunities are listed (the `source` field). Funder programs are real; verify the exact current deadline and terms at the entry `url` before applying. No grants are invented.",
    "deadline_convention": "`rolling` = continuously open; `annual` = recurring annual call with a window that varies year to year (verify at source); otherwise an ISO YYYY-MM-DD date.",
    "requirement_codes": {
      "registered_entity": "Org must be a legally registered entity.",
      "min_years_operating": "Org must have operated at least `value` years.",
      "audited_accounts": "Org must have audited financial statements.",
      "functioning_board": "Org must have a functioning board/governance body."
    },
    "public_sources_consolidated": [
      "AfricanNGOs.org monthly funding roundups",
      "FundsforNGOs Africa listings",
      "GlobalGiving / Instrumentl Africa browse pages",
      "Africa-Grants.com latest grants + eligibility pages"
    ]
  },
